---
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  forceDark?: boolean;
  variant?: 'logomark' | 'full';
  class?: string;
  letter?: string;
}

const { size = 'md', class: className } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm:    'w-5 h-5',
  md:    'w-6 h-6',
  lg:    'w-8 h-8',
  xl:    'w-12 h-12',
  '2xl': 'w-24 h-24',
};

const box = sizeClasses[size] ?? sizeClasses.md;
---

<img
  src="/logo.png"
  alt={siteConfig.branding.logo.alt}
  class={cn('inline-block shrink-0 object-contain', box, className)}
/>
