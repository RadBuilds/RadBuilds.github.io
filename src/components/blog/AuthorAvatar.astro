---
import siteConfig from '@/config/site.config';

interface Props {
  author: string;
  size?: 'sm' | 'md';
}

const { author, size = 'md' } = Astro.props;

const sizeClasses = size === 'sm'
  ? 'h-7 w-7 text-xs'
  : 'h-9 w-9 text-sm';
---

{siteConfig.authorImage
  ? <img src={siteConfig.authorImage} alt={author} class:list={['rounded-full object-cover', sizeClasses]} />
  : <span class:list={['rounded-full bg-brand-500 flex items-center justify-center font-semibold text-white', sizeClasses]}>{author.charAt(0).toUpperCase()}</span>
}
