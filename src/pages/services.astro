---
/**
 * Services page
 * URL: /services
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---
<PageLayout
  title="Services — Fractional CTO | RadBuilds"
  description="Two ways to engage: a fixed-scope Technical Diagnostic Sprint, or ongoing fractional CTO support across three commitment tiers."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="sparkles" size="sm" />
      Services
    </Badge>
    <h1 slot="title">
      <span class="text-foreground">What I offer —</span><br />
      <span class="text-brand-500">two ways to engage.</span>
    </h1>

    <p slot="description">
      Every engagement starts with a short, defined diagnostic. If it makes sense to continue,
      we move to an ongoing retainer — the scope shaped around what your company actually needs.
    </p>

    <Fragment slot="actions">
      <Button variant="outline" href="#diagnostic">
        Diagnostic Sprint
        <Icon name="arrow-down" size="sm" />
      </Button>
      <Button variant="outline" href="#retainer">
        Ongoing Retainer
        <Icon name="arrow-down" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Diagnostic Sprint -->
  <section id="diagnostic" class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Text -->
        <div class="flex flex-col justify-center gap-4" data-reveal="right" data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start">
            <Icon name="search" size="sm" />
            Technical Diagnostic Sprint
          </Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Clarity in two weeks
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            A focused two-week assessment of your stack, architecture, delivery practices, and team setup.
            Fixed scope. Fixed price. A prioritised, specific picture of what's working, what's fragile, and what to fix first.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Not a generic audit — the output is sequenced for your stage and goals. Most of the time this leads to an ongoing engagement.
            Sometimes the diagnosis is all you need. Either way, you leave with clarity.
          </p>
          <Button variant="outline" href="/contact" class="self-start mt-2">
            Start with a conversation
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <!-- Card: What's included -->
        <div data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="h-full flex flex-col justify-center">
            <div class="flex items-center gap-3 pb-4 mb-4 border-b border-border">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="search" size="md" />
              </div>
              <h3 class="font-display text-base font-semibold text-foreground">What's covered</h3>
            </div>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-muted leading-relaxed">
                  <span class="font-semibold text-foreground">Architecture review</span> — current state, scalability risks, key structural decisions and their consequences.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-muted leading-relaxed">
                  <span class="font-semibold text-foreground">Codebase health</span> — tech debt hot spots, dependency risks, test coverage reality.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-muted leading-relaxed">
                  <span class="font-semibold text-foreground">Delivery practices</span> — how the team actually works, where time is lost, what slows you down.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-muted leading-relaxed">
                  <span class="font-semibold text-foreground">Team setup</span> — skills mapping, communication patterns, hiring gaps.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-muted leading-relaxed">
                  <span class="font-semibold text-foreground">Security & compliance posture</span> — surface-level flags, not a pentest.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-muted leading-relaxed">
                  <span class="font-semibold text-foreground">90-day action plan</span> — sequenced, specific, realistic for your team size.
                </p>
              </li>
            </ul>
          </Card>
        </div>
      </div>

      <!-- Deliverables row -->
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-children>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              <Icon name="file-text" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-foreground">Technical Landscape</h3>
              <p class="text-xs text-foreground-muted leading-relaxed mt-1">
                Current state, architecture diagram, and key risks — documented.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="alert-triangle" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-foreground">Risk Register</h3>
              <p class="text-xs text-foreground-muted leading-relaxed mt-1">
                Prioritised list of what could hurt you and when.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="list-ordered" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-foreground">90-Day Action Plan</h3>
              <p class="text-xs text-foreground-muted leading-relaxed mt-1">
                Sequenced next steps, scoped to your team size and pace.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="presentation" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-foreground">Readout Session</h3>
              <p class="text-xs text-foreground-muted leading-relaxed mt-1">
                90-min live walkthrough with founder and key team members.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Ongoing Retainer -->
  <section id="retainer" class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-10">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>
            <Icon name="repeat" size="sm" />
            Ongoing Retainer
          </Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Fractional CTO, ongoing
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          The diagnostic surfaces the problems — the retainer installs the fixes.
          Three commitment tiers; the right one depends on how involved your technical situation needs me to be.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3" data-reveal-children>
        <!-- Strategic -->
        <Card variant="elevated" padding="lg" class="flex flex-col gap-4">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="compass" size="md" />
            </div>
            <div>
              <h3 class="font-display text-base font-semibold text-foreground">Strategic</h3>
              <p class="text-xs text-foreground-muted">1 day / week</p>
            </div>
          </div>
          <p class="text-sm text-foreground-muted leading-relaxed">
            Best when the team is capable and you mostly need a senior technical voice for direction and sanity-checks.
          </p>
          <ul class="flex flex-col gap-2 mt-auto">
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Weekly exec sync</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Architecture decisions</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Hiring input</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Async availability</span>
            </li>
          </ul>
        </Card>

        <!-- Active -->
        <Card variant="elevated" padding="lg" class="flex flex-col gap-4 ring-2 ring-brand-500/30">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="activity" size="md" />
            </div>
            <div>
              <h3 class="font-display text-base font-semibold text-foreground">Active</h3>
              <p class="text-xs text-foreground-muted">2 days / week</p>
            </div>
          </div>
          <p class="text-sm text-foreground-muted leading-relaxed">
            When delivery is inconsistent, architecture decisions are backing up, or you're hiring and need someone to own the process.
          </p>
          <ul class="flex flex-col gap-2 mt-auto">
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Everything in Strategic</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Delivery rhythm ownership</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Sprint reviews</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Team coaching</span>
            </li>
          </ul>
        </Card>

        <!-- Embedded -->
        <Card variant="elevated" padding="lg" class="flex flex-col gap-4">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layers" size="md" />
            </div>
            <div>
              <h3 class="font-display text-base font-semibold text-foreground">Embedded</h3>
              <p class="text-xs text-foreground-muted">3 days / week</p>
            </div>
          </div>
          <p class="text-sm text-foreground-muted leading-relaxed">
            For major transitions: cloud migration, AI integration, regulatory compliance, or scaling from 5 to 15 engineers.
          </p>
          <ul class="flex flex-col gap-2 mt-auto">
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Everything in Active</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Deeper hands-on involvement</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Suitable for crunch periods</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-0.5" />
              <span class="text-xs text-foreground-muted">Rapid scale support</span>
            </li>
          </ul>
        </Card>
      </div>

      <p class="text-sm text-foreground-muted text-center" data-reveal>
        Minimum commitment: 3 months. Always includes: async availability (response within business day), monthly strategy session with founder, and written monthly summary of decisions and progress.
      </p>
    </div>
  </section>

  <!-- How to Start -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>How it works</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            How to start
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Three steps. No pitch, no long sales process.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        <Card hover data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              1
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Discovery call</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                30 minutes. You describe your situation; I ask about the technical landscape. No obligation — this call tells both of us whether there's a fit.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              2
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Proposal</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                If there's a fit: a tailored diagnostic scope within 48 hours. Fixed price, clear deliverables, defined timeline. No surprises.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              3
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Sprint starts</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Diagnostic begins within two weeks of signature. From there, most engagements move into an ongoing retainer shaped around what you actually need.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Start with a 30-minute discovery call. I read every message and reply within a working day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="cta-btn-brand">
          Book a discovery call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          More about me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Start with a 30-minute discovery call. I read every message and reply within a working day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Book a discovery call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          More about me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>

<style is:global>
  html { scroll-padding-top: 4rem; }
</style>
