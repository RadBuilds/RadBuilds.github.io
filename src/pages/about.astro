---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---
<PageLayout
  title="About Radosław Domański — Fractional CTO"
  description="15+ years from developer to CTO, across fintech, AI, and scale-ups. Fractional CTO for early-stage startups and scale-ups."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      About me
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Radek Domański —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["Fractional CTO", "Systems Thinker", "Technical Leader", "Engineering Coach", "AI Builder"]} />
      </span>
    </h1>

    <p slot="description">
      15+ years from developer to CTO across fintech, AI, and scale-ups.
      Here's how I think, who I work with, and what I actually do.
    </p>
  </Hero>

  <!-- Who I work with -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Text -->
        <div class="flex flex-col gap-4" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6">
            <Badge variant="brand" pill class="self-start">Who I work with</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              The pre-CTO gap
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Seed done, first product live, a few engineers on the team. Technical decisions are starting to compound —
            architecture, hiring, delivery rhythm — but a full-time CTO hire isn't yet justified or hasn't landed.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            That's the gap I fill. I come in as a part-time technical partner: owning the decisions a founder shouldn't be
            making alone, and building the systems the team needs to grow without me.
          </p>
        </div>
        <!-- Right: fit cards -->
        <div class="flex flex-col gap-4 h-full" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" class="flex-1 flex flex-col justify-center">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="check-circle" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">Good fit</p>
                <ul class="flex flex-col gap-1.5 mt-1">
                  <li class="text-sm text-foreground-muted">Seed-stage or post-Series A company</li>
                  <li class="text-sm text-foreground-muted">No full-time CTO in seat yet</li>
                  <li class="text-sm text-foreground-muted">A few engineers, initial stages of the product</li>
                  <li class="text-sm text-foreground-muted">Decisions starting to back up</li>
                  <li class="text-sm text-foreground-muted">Poland / EU (US possible)</li>
                </ul>
              </div>
            </div>
          </Card>
          <Card variant="elevated" class="flex-1 flex flex-col justify-center">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="x-circle" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">Not a fit</p>
                <ul class="flex flex-col gap-1.5 mt-1">
                  <li class="text-sm text-foreground-muted">Company already has a strong CTO or VP Eng</li>
                  <li class="text-sm text-foreground-muted">Pre-product (no tech to review yet)</li>
                </ul>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement model -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col items-center gap-6 text-center" data-reveal>
      <Badge variant="brand" pill>How I engage</Badge>
      <p class="text-lg text-foreground-muted max-w-2xl text-balance">
        Every engagement starts with a two-week Technical Diagnostic Sprint — fixed scope, fixed price, prioritised action plan as output.
        From there, most continue on an ongoing retainer shaped around what the company actually needs.
      </p>
      <Button variant="outline" href="/services">
        Full engagement details
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>

  <!-- What makes me different -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Background</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            What I bring
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          15+ years from developer to tech lead to CTO — across telco, insurance, fintech, blockchain, and AI.
        </p>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        <Card hover data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="compass" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Systems thinker</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                The expensive mistakes are almost never technical failures — they're decisions to build the wrong thing,
                in the wrong order, for the wrong reasons. I optimise for direction, not just velocity.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="users" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Teaching instinct</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                I don't just make decisions — I transfer knowledge and build team capability. The test of a good engagement:
                the team is stronger when it ends than when it started.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layers" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Breadth as a moat</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Not a stack specialist. The problems that set companies back 6–12 months rarely live in one technology —
                they live at the seams. 15+ years across industries and stacks is the point.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <TechStack
    badge="Tech background"
    title="Stack & Tools"
    description="Technologies I've worked with across production systems — from AI-integrated products to regulated fintech backends."
    background="primary"
  />

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a good fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Start with a 30-minute call. No pitch — just a conversation about your situation.
      </p>
      <Button size="lg" href="/contact" class="cta-btn-brand">
        Book a discovery call
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a good fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Start with a 30-minute call. No pitch — just a conversation about your situation.
      </p>
      <Button size="lg" href="/contact" class="hero-btn-brand">
        Book a discovery call
        <Icon name="arrow-right" size="sm" />
      </Button>
    </LetterGlitchBand>
  </section>
</PageLayout>
