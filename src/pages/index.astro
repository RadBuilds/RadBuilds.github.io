---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';
import { getPostSlug } from '@/lib/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="Radek Domański — Fractional CTO"
  description="Fractional CTO for early-stage startups and scale-ups. I help founders build the right thing — before the wrong decisions compound."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator>

    <h1 slot="title" class="!text-[clamp(2rem,11.2vw,3rem)] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">Build the</span><br />
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">right thing.</span>
    </h1>

    <p slot="description">
      Fractional CTO for early-stage startups and scale-ups. I help technical founders make the decisions
      that matter — architecture, team, delivery — before the wrong ones compound.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="/contact" class="hero-btn-brand">
        Book a discovery call
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/services">
        What I offer
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Services preview -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>How I engage</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Two ways to work together
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Everything starts with a short, defined diagnostic sprint. If it makes sense to continue, we move to an ongoing retainer.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <Card hover href="/services#diagnostic" class="group flex flex-col" data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="search" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Technical Diagnostic Sprint</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Two weeks. Fixed scope and price. Architecture, codebase health, delivery practices, team setup.
                Delivers a prioritised action plan.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Learn more
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>

        <Card hover href="/services#retainer" class="group flex flex-col" data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="repeat" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Ongoing Retainer</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                1–3 days per week. Strategic direction, delivery rhythm, hiring, team coaching.
                Three tiers depending on how much involvement your situation needs.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Learn more
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- About teaser -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 mb-6">
            <Badge variant="brand" pill class="self-start">About me</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Systems thinker,<br />
              <span class="text-brand-500">not task executor.</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4">
            15+ years from developer to tech lead to CTO — across fintech, AI, blockchain, telco, and insurance.
            I work with founders who aren't sure they're building in the right direction.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            Not a stack specialist. The calls that cost companies 6–12 months don't live in a single technology — they live between teams, systems, and priorities.
          </p>
          <Button variant="outline" href="/about" class="self-start">
            More about me
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <p class="text-sm text-foreground mb-5 text-center">A few things about me.</p>
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="history" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">15+ Years</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="map-pin" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Poland & EU</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="cpu" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">AI & Fintech</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="users" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Team coaching</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  {posts.length > 0 && (
    <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
        <div class="flex flex-col items-center gap-6 text-center" data-reveal>
          <Badge variant="brand" pill>From the blog</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Recent writing
          </h2>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={`/blog/${getPostSlug(post.id)}`}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              author={post.data.author}
              image={post.data.image}
              svgSlug={post.data.svgSlug}
            />
          ))}
        </div>

        <div class="flex justify-center">
          <Button variant="outline" href="/blog">
            View all posts
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Start with a 30-minute call. No pitch — just a conversation about your situation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="cta-btn-brand">
          Book a discovery call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/services">
          See how it works
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Start with a 30-minute call. No pitch — just a conversation about your situation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Book a discovery call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/services">
          See how it works
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>

</LandingLayout>
